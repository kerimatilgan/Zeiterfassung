generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./zeiterfassung.db"
}

// Mitarbeiter
model Employee {
  id                  String   @id @default(uuid())
  employeeNumber      String   @unique // Mitarbeiternummer
  username            String?  @unique // Benutzername für Login
  firstName           String
  lastName            String
  email               String?  @unique
  phone               String?
  photoUrl            String?  // Pfad zum Mitarbeiterfoto
  qrCode              String   @unique // Eindeutiger QR-Code für Zeiterfassung
  rfidCard            String?  @unique // RFID-Karten-ID für Stempelterminal
  pin                 String?  // Optional: PIN für manuelle Eingabe
  startDate           DateTime? // Eintrittsdatum (ab wann Arbeitszeit/Urlaub berechnet wird)
  endDate             DateTime? // Austrittsdatum (ab diesem Tag kann sich MA nicht mehr einstempeln)
  weeklyHours         Float    @default(40.0) // Vertraglich vereinbarte Wochenstunden
  vacationDaysPerYear Int      @default(30) // Urlaubsanspruch pro Jahr
  carryOverVacationDays Int    @default(0) // Resturlaub aus dem Vorjahr (automatisch berechnet)
  workDays            String   @default("1,2,3,4,5") // Arbeitstage (0=So, 1=Mo, ..., 6=Sa)
  isActive            Boolean  @default(true)
  isAdmin             Boolean  @default(false)
  passwordHash        String?  // Für Dashboard-Login
  passwordResetToken  String?  // Token für Passwort-Reset
  passwordResetExpires DateTime? // Ablaufzeit des Reset-Tokens
  totpSecret          String?  // Base32-encoded TOTP Secret
  totpEnabled         Boolean  @default(false) // 2FA aktiviert
  workCategoryId      String?       // Arbeitskategorie (früheste Einstempelzeit)
  workCategory        WorkCategory? @relation(fields: [workCategoryId], references: [id], onDelete: SetNull)

  // Reguläres Arbeitszeitende (für Auto-Ausstempeln)
  defaultClockOut     String?  // z.B. "17:00" - wird bei Auto-Ausstempeln verwendet

  // PWA-Stempelung Berechtigungen
  canClockInPwa   Boolean @default(false) // Darf sich über PWA einstempeln
  canClockOutPwa  Boolean @default(false) // Darf sich über PWA ausstempeln

  // Initiale Salden (Import aus alter Software)
  initialOvertimeBalance  Float   @default(0) // Überstunden-Saldo Startwert
  initialVacationDaysUsed Int     @default(0) // Bereits genommene Urlaubstage
  initialSickDays         Int     @default(0) // Bisherige Krankheitstage im Jahr
  initialBalanceYear      Int?               // Ab welchem Jahr gelten die Startwerte
  initialBalanceMonth     Int?               // Ab welchem Monat gelten die Startwerte

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  timeEntries         TimeEntry[]
  monthlyReports      MonthlyReport[]
  absences            EmployeeAbsence[]
  passkeys            Passkey[]
  documents           Document[]
  vacationDeductions  VacationDeduction[]
  vacationAdjustments VacationAdjustment[]
  complaints          Complaint[]
}

// Passkeys (WebAuthn)
model Passkey {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  credentialId    String   @unique // Base64url-encoded credential ID
  publicKey       String   // Base64url-encoded public key
  counter         Int      @default(0) // Signature counter
  deviceName      String?  // Friendly name, e.g. "MacBook Pro"
  transports      String?  // JSON array of transports

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Zeiteinträge (Stempeln)
model TimeEntry {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  clockIn     DateTime  // Einstempeln
  clockOut    DateTime? // Ausstempeln (null = noch eingestempelt)

  breakMinutes Int      @default(0) // Pausenzeit in Minuten

  note        String?   // Optionale Notiz
  isManual    Boolean   @default(false) // Manuell eingetragen vs. gescannt
  editedBy    String?   // Falls bearbeitet: von wem

  // PWA-Stempelung
  clockInViaPwa     Boolean  @default(false) // Über PWA eingestempelt
  clockOutViaPwa    Boolean  @default(false) // Über PWA ausgestempelt
  clockInLatitude   Float?   // GPS Breitengrad beim Einstempeln
  clockInLongitude  Float?   // GPS Längengrad beim Einstempeln
  clockOutLatitude  Float?   // GPS Breitengrad beim Ausstempeln
  clockOutLongitude Float?   // GPS Längengrad beim Ausstempeln
  pwaClockInReasonId   String?  // Vordefinierter Grund fürs Einstempeln via PWA
  pwaClockInReasonText String?  // Freitext-Grund fürs Einstempeln via PWA
  pwaClockOutReasonId   String?  // Vordefinierter Grund fürs Ausstempeln via PWA
  pwaClockOutReasonText String?  // Freitext-Grund fürs Ausstempeln via PWA

  // Reklamation durch Mitarbeiter
  complaintMessage     String?    // Nachricht des Mitarbeiters
  complaintAt          DateTime?  // Zeitpunkt der Reklamation
  complaintResolvedAt  DateTime?  // Zeitpunkt der Bearbeitung durch Admin
  complaintResolvedBy  String?    // Admin-ID der bearbeitet hat
  complaintResponse    String?    // Antwort des Admins (optional)
  // Originalwerte bei Reklamation (für vorher/nachher Vergleich)
  complaintOriginalClockIn     DateTime?
  complaintOriginalClockOut    DateTime?
  complaintOriginalBreakMinutes Int?

  // Reklamations-Historie (mehrere Reklamationen pro Eintrag möglich)
  complaints  Complaint[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Reklamationen (jede Reklamation ein eigener Datensatz - Historie)
model Complaint {
  id                String   @id @default(uuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Optional: zu welchem TimeEntry gehört die Reklamation
  // Bei Standalone-Reklamationen (Tag ohne Stempelung) bleibt das null
  timeEntryId       String?
  timeEntry         TimeEntry? @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)

  // Tag, auf den sich die Reklamation bezieht (für Standalone wichtig)
  date              DateTime

  // Nachricht des Mitarbeiters
  message           String

  // Snapshot der Werte zum Zeitpunkt der Reklamation (für Vorher-/Nachher-Anzeige)
  originalClockIn       DateTime?
  originalClockOut      DateTime?
  originalBreakMinutes  Int?

  // Bearbeitung durch Admin
  resolvedAt        DateTime?
  resolvedBy        String?   // Admin-ID
  resolvedByName    String?   // Admin-Name (Snapshot)
  response          String?

  // Werte nach Bearbeitung (für Vorher-/Nachher-Vergleich auch nach späteren Änderungen)
  newClockIn        DateTime?
  newClockOut       DateTime?
  newBreakMinutes   Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Monatsabrechnungen
model MonthlyReport {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  year            Int
  month           Int      // 1-12

  totalHours      Float    // Gesamtstunden im Monat
  targetHours     Float    // Soll-Stunden
  overtimeHours   Float    // Differenz Monat (kann negativ sein = Minusstunden)

  // Überstunden-Übertrag
  previousOvertimeBalance   Float @default(0)  // Übertrag Überstunden-Saldo vom Vormonat
  cumulativeOvertimeBalance Float @default(0)  // Gesamt-Saldo = previous + overtimeHours

  // Urlaubstage-Tracking
  vacationDaysUsed      Int @default(0) // Verbrauchte Urlaubstage bis einschließlich dieses Monats
  vacationDaysRemaining Int @default(0) // Verbleibende Urlaubstage

  // Minusstunden-Urlaubsabzug
  vacationDeductionDays   Int    @default(0) // In dieser Abrechnung abgezogene Urlaubstage
  vacationDeductionHours  Float  @default(0) // Dafür gutgeschriebene Stunden
  vacationDeductionNote   String? // Info-Text für den Abzug

  // Krankheitstage-Tracking
  sickDaysThisMonth     Int @default(0)  // Krankheitstage in diesem Monat
  sickDaysTotal         Int @default(0)  // Kumulative Krankheitstage im Jahr

  status          String   @default("draft") // draft, finalized, paid
  pdfPath         String?  // Pfad zur generierten PDF

  notes           String?
  createdBy       String   // Admin der die Abrechnung erstellt hat
  finalizedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, year, month])
}

// Einstellungen
model Settings {
  id                    String  @id @default("default")
  companyName           String  @default("Handy-Insel")
  companyAddress        String?
  companyPhone          String?
  companyEmail          String?

  defaultBreakMinutes   Int     @default(30) // Standard-Pause bei > 6h
  overtimeThreshold     Float   @default(40.0) // Ab wann Überstunden zählen (Wochenstunden)

  // Backup-Konfiguration
  backupFrequency       String  @default("daily") // hourly, daily, weekly
  backupTime            String  @default("02:00") // Uhrzeit für tägliches/wöchentliches Backup
  backupWeekday         Int     @default(1) // Wochentag für wöchentliches Backup (1=Mo)
  backupRetentionDays   Int     @default(30) // Aufbewahrungsdauer in Tagen

  // Mail-Server Konfiguration
  smtpHost              String?
  smtpPort              Int?     @default(587)
  smtpUser              String?
  smtpPassword          String?
  smtpFromAddress       String?
  smtpFromName          String?  @default("Zeiterfassung")
  smtpSecure            Boolean  @default(false) // true für TLS

  // PDF-Optionen
  pdfShowWorkCategory   Boolean  @default(false) // Arbeitskategorie auf Abrechnung anzeigen

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Feiertage / freie Tage
model Holiday {
  id          String   @id @default(uuid())
  date        DateTime
  name        String
  isRecurring Boolean  @default(false) // Jährlich wiederkehrend

  createdAt   DateTime @default(now())
}

// Abwesenheitstypen (konfigurierbar: Urlaub, Schule, etc.)
model AbsenceType {
  id              String   @id @default(uuid())
  name            String   // z.B. "Urlaub", "Berufsschule (ganztags)", "Berufsschule (halbtags)"
  shortName       String   // z.B. "U", "BS", "BS½"
  requiredHours   Float    @default(0) // Pflichtstunden an diesem Tag (0 = keine Pflicht)
  color           String   @default("#3B82F6") // Farbe für Anzeige im Kalender
  countsAsVacation Boolean @default(false) // Zählt als Urlaubstag (true = wird vom Urlaubskontingent abgezogen)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0) // Reihenfolge in Dropdowns

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  absences        EmployeeAbsence[]
}

// Mitarbeiter-Abwesenheiten
model EmployeeAbsence {
  id              String      @id @default(uuid())
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  absenceTypeId   String
  absenceType     AbsenceType @relation(fields: [absenceTypeId], references: [id], onDelete: Cascade)
  date            DateTime    // Das Datum der Abwesenheit
  note            String?     // Optionale Notiz

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([employeeId, date]) // Ein Mitarbeiter kann pro Tag nur eine Abwesenheit haben
}

// Arbeitskategorien (z.B. Backoffice, Büro, Verkauf)
model WorkCategory {
  id              String   @id @default(uuid())
  name            String   // z.B. "Backoffice", "Büro", "Verkauf"
  earliestClockIn String   // Früheste Einstempelzeit im Format "HH:mm", z.B. "08:00"
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employees       Employee[]
}

// Audit-Log für Nachvollziehbarkeit aller Aktionen
model AuditLog {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())

  userId      String?  // Wer hat die Aktion ausgeführt (Employee-ID)
  userName    String?  // Name des Users für schnelle Anzeige

  action      String   // LOGIN, LOGOUT, CLOCK_IN, CLOCK_OUT, CREATE, UPDATE, DELETE
  entityType  String   // Employee, TimeEntry, Report, Settings, Holiday, AbsenceType, Absence
  entityId    String?  // ID des betroffenen Datensatzes

  oldValues   String?  // JSON der alten Werte (bei UPDATE/DELETE)
  newValues   String?  // JSON der neuen Werte (bei CREATE/UPDATE)

  ipAddress   String?  // IP-Adresse des Clients
  userAgent   String?  // Browser/Client Info
  note        String?  // Zusätzliche Info
}

// Dokumenttypen (konfigurierbar: Gehaltsabrechnung, Provisionsabrechnung, etc.)
model DocumentType {
  id        String     @id @default(uuid())
  name      String     // z.B. "Gehaltsabrechnung"
  shortName String     // z.B. "GA"
  color     String     @default("#6366F1")
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  documents Document[]
}

// Dokumente (pro Mitarbeiter hochgeladen)
model Document {
  id               String       @id @default(uuid())
  employeeId       String
  employee         Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documentTypeId   String
  documentType     DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  filePath         String
  originalFilename String
  fileSize         Int
  mimeType         String
  year             Int?
  month            Int?
  note             String?
  uploadedBy       String
  uploadedByName   String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

// Urlaubsabzüge bei Minusstunden
model VacationDeduction {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year        Int      // Jahr in dem der Abzug stattfand
  month       Int      // Monat (1-12)
  reason      String   // z.B. "Minusstunden-Ausgleich: -8:30h → 1 Urlaubstag"
  daysDeducted Int     @default(1) // Abgezogene Urlaubstage
  hoursCompensated Float // Gutgeschriebene Stunden
  overtimeBalanceBefore Float // Überstunden-Saldo vor Abzug
  overtimeBalanceAfter Float  // Überstunden-Saldo nach Abzug
  createdAt   DateTime @default(now())
}

// Manuelle Urlaubsanpassungen (hinzufügen/abziehen durch Admin)
model VacationAdjustment {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year        Int
  month       Int      // 1-12
  days        Float    // positiv = hinzufügen, negativ = abziehen
  reason      String
  createdBy   String   // Admin-Name
  createdAt   DateTime @default(now())
}

// PWA-Stempel-Gründe (vordefinierte Auswahlmöglichkeiten)
model PwaClockReason {
  id        String   @id @default(uuid())
  name      String   // z.B. "Außentermin", "Homeoffice", "Arztbesuch"
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Backup-Ziele (Speicherorte für Backups)
model BackupTarget {
  id          String   @id @default(uuid())
  name        String                    // z.B. "Office NAS", "Cloud S3"
  type        String                    // local, smb, nfs, sftp, webdav, dropbox, gdrive, onedrive, s3
  isActive    Boolean  @default(true)
  config      String                    // JSON-Konfiguration (AES-256 verschlüsselt)
  lastTestAt  DateTime?
  lastTestOk  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  backupRecords BackupRecord[]
}

// Backup-Protokoll
model BackupRecord {
  id             String        @id @default(uuid())
  targetId       String?
  target         BackupTarget? @relation(fields: [targetId], references: [id], onDelete: SetNull)
  filename       String        // z.B. "zeiterfassung_2026-03-21_020000.tar.gz"
  fileSize       Int           @default(0)
  status         String        @default("pending") // pending, success, failed
  errorMessage   String?
  trigger        String        @default("scheduled") // scheduled, manual
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  expiresAt      DateTime?     // Für automatische Bereinigung
  createdAt      DateTime      @default(now())
}

// Terminals (Pi-Stempelterminals)
model Terminal {
  id          String    @id @default(uuid())
  name        String                      // z.B. "Terminal Eingang", "Terminal Lager"
  apiKey      String    @unique           // Sicherer API-Key
  isActive    Boolean   @default(true)
  lastSeen    DateTime?                   // Letzter authentifizierter Request
  ipAddress   String?                     // IP-Adresse des Terminals
  version     String?                     // Software-Version
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
