generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./zeiterfassung.db"
}

// Mitarbeiter
model Employee {
  id                  String   @id @default(uuid())
  employeeNumber      String   @unique // Mitarbeiternummer
  firstName           String
  lastName            String
  email               String?  @unique
  phone               String?
  qrCode              String   @unique // Eindeutiger QR-Code für Zeiterfassung
  rfidCard            String?  @unique // RFID-Karten-ID für Stempelterminal
  pin                 String?  // Optional: PIN für manuelle Eingabe
  weeklyHours         Float    @default(40.0) // Vertraglich vereinbarte Wochenstunden
  vacationDaysPerYear Int      @default(30) // Urlaubsanspruch pro Jahr
  workDays            String   @default("1,2,3,4,5") // Arbeitstage (0=So, 1=Mo, ..., 6=Sa)
  isActive            Boolean  @default(true)
  isAdmin             Boolean  @default(false)
  passwordHash        String?  // Für Dashboard-Login

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  timeEntries     TimeEntry[]
  monthlyReports  MonthlyReport[]
  absences        EmployeeAbsence[]
}

// Zeiteinträge (Stempeln)
model TimeEntry {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  clockIn     DateTime  // Einstempeln
  clockOut    DateTime? // Ausstempeln (null = noch eingestempelt)

  breakMinutes Int      @default(0) // Pausenzeit in Minuten

  note        String?   // Optionale Notiz
  isManual    Boolean   @default(false) // Manuell eingetragen vs. gescannt
  editedBy    String?   // Falls bearbeitet: von wem

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Monatsabrechnungen
model MonthlyReport {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  year            Int
  month           Int      // 1-12

  totalHours      Float    // Gesamtstunden im Monat
  targetHours     Float    // Soll-Stunden
  overtimeHours   Float    // Überstunden

  // Urlaubstage-Tracking
  vacationDaysUsed      Int @default(0) // Verbrauchte Urlaubstage bis einschließlich dieses Monats
  vacationDaysRemaining Int @default(0) // Verbleibende Urlaubstage

  status          String   @default("draft") // draft, finalized, paid
  pdfPath         String?  // Pfad zur generierten PDF

  notes           String?
  createdBy       String   // Admin der die Abrechnung erstellt hat
  finalizedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, year, month])
}

// Einstellungen
model Settings {
  id                    String  @id @default("default")
  companyName           String  @default("Handy-Insel")
  companyAddress        String?
  companyPhone          String?
  companyEmail          String?

  defaultBreakMinutes   Int     @default(30) // Standard-Pause bei > 6h
  overtimeThreshold     Float   @default(40.0) // Ab wann Überstunden zählen (Wochenstunden)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Feiertage / freie Tage
model Holiday {
  id          String   @id @default(uuid())
  date        DateTime
  name        String
  isRecurring Boolean  @default(false) // Jährlich wiederkehrend

  createdAt   DateTime @default(now())
}

// Abwesenheitstypen (konfigurierbar: Urlaub, Schule, etc.)
model AbsenceType {
  id              String   @id @default(uuid())
  name            String   // z.B. "Urlaub", "Berufsschule (ganztags)", "Berufsschule (halbtags)"
  shortName       String   // z.B. "U", "BS", "BS½"
  requiredHours   Float    @default(0) // Pflichtstunden an diesem Tag (0 = keine Pflicht)
  color           String   @default("#3B82F6") // Farbe für Anzeige im Kalender
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0) // Reihenfolge in Dropdowns

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  absences        EmployeeAbsence[]
}

// Mitarbeiter-Abwesenheiten
model EmployeeAbsence {
  id              String      @id @default(uuid())
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  absenceTypeId   String
  absenceType     AbsenceType @relation(fields: [absenceTypeId], references: [id], onDelete: Cascade)
  date            DateTime    // Das Datum der Abwesenheit
  note            String?     // Optionale Notiz

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([employeeId, date]) // Ein Mitarbeiter kann pro Tag nur eine Abwesenheit haben
}

// Audit-Log für Nachvollziehbarkeit aller Aktionen
model AuditLog {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())

  userId      String?  // Wer hat die Aktion ausgeführt (Employee-ID)
  userName    String?  // Name des Users für schnelle Anzeige

  action      String   // LOGIN, LOGOUT, CLOCK_IN, CLOCK_OUT, CREATE, UPDATE, DELETE
  entityType  String   // Employee, TimeEntry, Report, Settings, Holiday, AbsenceType, Absence
  entityId    String?  // ID des betroffenen Datensatzes

  oldValues   String?  // JSON der alten Werte (bei UPDATE/DELETE)
  newValues   String?  // JSON der neuen Werte (bei CREATE/UPDATE)

  ipAddress   String?  // IP-Adresse des Clients
  userAgent   String?  // Browser/Client Info
  note        String?  // Zusätzliche Info
}
