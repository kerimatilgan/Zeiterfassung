# ─── Pflicht ────────────────────────────────────────────────────────────────
# Mind. 32 Zeichen. Bei Änderung müssen sich alle Nutzer neu anmelden.
JWT_SECRET="CHANGE_ME_openssl_rand_hex_32"

# Genau 64 Hex-Zeichen (openssl rand -hex 32). Verschlüsselt Dokumente,
# Backup-Target-Configs und steht in passphrase-geschützten Backups.
# NIEMALS ändern, sonst sind bestehende Dokumente unlesbar.
DOCUMENT_ENCRYPTION_KEY="CHANGE_ME_openssl_rand_hex_32"

# Öffentliche URL des Frontends. Wird in Password-Reset-Mails verwendet und
# bestimmt die erlaubte CORS-Origin. Mehrere kommagetrennt möglich.
# Leer lassen = CORS permissiv (nur für lokale Tests).
FRONTEND_URL="https://zeit.example.de"

# ─── Optional ───────────────────────────────────────────────────────────────
# Port des Backends (Default 3001)
PORT=3001

# SQLite-Datei (Default file:./zeiterfassung.db, relativ zu backend/)
DATABASE_URL="file:./zeiterfassung.db"

# Web-Push (Browser-Benachrichtigungen). Einmalig erzeugen mit:
#   npx web-push generate-vapid-keys
# VAPID_SUBJECT muss mailto: oder https:// sein. Ohne diese 3 Werte ist
# Web-Push einfach deaktiviert. Werden in passphrase-geschützten Backups
# mitgesichert (anders als JWT_SECRET).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.de"

# Basis-URL für Links in automatischen Benachrichtigungen (z.B. Auto-Ausstempeln).
# Fällt auf FRONTEND_URL-Logik zurück, wenn nicht gesetzt.
APP_URL="https://zeit.example.de"

# Passphrase für GEPLANTE (automatische) Backups. Wenn gesetzt (≥ 8 Zeichen),
# werden Scheduled Backups als .tar.gz.enc verschlüsselt und enthalten dann
# DOCUMENT_ENCRYPTION_KEY + VAPID-Keys (self-contained). Leer = unverschlüsselt.
BACKUP_PASSPHRASE=""

# Legacy: Fallback-Terminal-API-Key. Neue Terminals bekommen DB-basierte Keys;
# dieser Wert wird nur für Alt-Installationen ohne DB-Terminals genutzt.
TERMINAL_API_KEY=""
