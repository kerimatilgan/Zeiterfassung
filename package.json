{
  "name": "zeiterfassung-handy-insel",
  "version": "1.0.0",
  "description": "Zeiterfassungssystem für Handy-Insel",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "backend": "npm run dev --workspace=backend",
    "frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "web-push": "^3.6.7"
  }
}
